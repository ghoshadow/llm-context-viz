{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "outDir": "dist-server",
    "rootDir": ".",
    "baseUrl": "."
  },
  "include": ["server", "src", "shared"],
  "exclude": [
    "server/**/*.test.ts",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "node_modules"
  ]
}
